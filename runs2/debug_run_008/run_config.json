{
  "args": {
    "env": "highway-v0",
    "preset": "highway_continuous_default",
    "total_steps": 600,
    "seed": 0,
    "p_stay": 0.5,
    "run_dir": "runs/debug_run_008",
    "no_mpc": false,
    "no_conformal": false,
    "epsilon": null,
    "delta_nearmiss": null,
    "use_budget": false,
    "budget_C": 10.0,
    "budget_T": 1000,
    "budget_risk_delta": 0.0,
    "budget_min_bt": 0.0,
    "model_name": "sac_model.zip"
  },
  "preset": {
    "env_config": {
      "observation": {
        "type": "Kinematics",
        "vehicles_count": 10,
        "features": [
          "presence",
          "x",
          "y",
          "vx",
          "vy"
        ],
        "absolute": false
      },
      "action": {
        "type": "ContinuousAction"
      },
      "lanes_count": 4,
      "vehicles_count": 30,
      "duration": 60,
      "policy_frequency": 1,
      "simulation_frequency": 15,
      "collision_reward": -10,
      "right_lane_reward": 0.1,
      "high_speed_reward": 0.4,
      "reward_speed_range": [
        20,
        30
      ]
    },
    "sac": {
      "learning_rate": 0.0003,
      "buffer_size": 100000,
      "learning_starts": 1000,
      "batch_size": 256,
      "tau": 0.005,
      "gamma": 0.99,
      "train_freq": 1,
      "gradient_steps": 1,
      "ent_coef": "auto",
      "policy_kwargs": {
        "net_arch": [
          256,
          256
        ]
      },
      "verbose": 1
    },
    "safety": {
      "epsilon": 6.0,
      "delta_nearmiss": 4.0
    },
    "fixed_obs_k": null
  }
}